# ==============================================================================
# AI Outfit Planner - Environment Variables
# Copy this file to .env and fill in the values.
# ==============================================================================

# Server Settings
PORT=8000
HOST=0.0.0.0
DEBUG=True

# Database Configuration
# Fallback to local SQLite database (sqlite:///./outfit_planner.db) if left blank
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/outfit_planner

# Firebase Auth Configuration
# Used on backend to verify ID tokens sent by the Flutter client
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_JSON=

# Cloudinary Configuration
# For uploading and hosting wardrobe images, user full-body model photos, and try-on results
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# AI Models & APIs Configuration
# Vision LLM (GPT-4o/Claude) used for auto-tagging garment photos
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Replicate API (IDM-VTON model) for virtual garment try-ons
REPLICATE_API_TOKEN=your-replicate-api-token

# Weather Context API (OpenWeatherMap free tier)
OPENWEATHER_API_KEY=your-openweather-api-key

# Payments & Monetization Configuration
# RevenueCat API for handling in-app subscriptions and premium gate validation
REVENUECAT_API_KEY=your-revenuecat-api-key
