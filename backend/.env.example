# ==============================================================================
# AI Outfit Planner - Environment Variables Example
# Copy this file to .env and fill in the values.
# ==============================================================================

# Server Settings
PORT=8000
HOST=0.0.0.0
DEBUG=True

# Database Configuration
# Fallback to local SQLite database (sqlite:///./outfit_planner.db) if left blank
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/outfit_planner

# Firebase Auth Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_JSON=

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# AI Models & APIs Configuration
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# DeepInfra API (FLUX Kontext model) for virtual garment try-ons
# Get your key at: https://deepinfra.com
DEEPINFRA_API_KEY=your-deepinfra-api-key

# Weather Context API (OpenWeatherMap free tier)
# Get your key at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# Payments & Monetization Configuration
REVENUECAT_API_KEY=your-revenuecat-api-key
